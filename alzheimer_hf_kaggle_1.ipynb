CLASSES   = ["MildDemented", "ModerateDemented", "NonDemented", "VeryMildDemented"]
CLASS2IDX = {c: i for i, c in enumerate(CLASSES)}
IDX2CLASS = {i: c for c, i in CLASS2IDX.items()}

print(f"Device: {CFG['device']}  |  AMP: {CFG['use_amp']}")
def seed_everything(seed: int):
    random.seed(seed); np.random.seed(seed)
    torch.manual_seed(seed); torch.cuda.manual_seed_all(seed)
    torch.backends.cudnn.deterministic = True
    torch.backends.cudnn.benchmark = False

def print_class_distribution(df, title=""):
    counts = df["label"].value_counts()
    total  = len(df)
    print(f"\n{'─'*45}")
    if title: print(f"  {title}")
    for cls in CLASSES:
        cnt = counts.get(cls, 0)
        bar = "█" * int(cnt / total * 40)
        print(f"  {cls:<22} {cnt:>6,}  ({cnt/total*100:5.1f}%)  {bar}")
    print(f"{'─'*45}")

def get_sample_weights(labels, beta=0.9999):
    counter = Counter(labels)
    weights_per_class = {cls: (1.0-beta)/(1.0-beta**n) for cls, n in counter.items()}
    total_w = sum(weights_per_class.values())
    for cls in weights_per_class: weights_per_class[cls] /= total_w
    return [weights_per_class[lbl] for lbl in labels]

def get_class_weights_for_loss(labels, beta=0.9999):
    counter = Counter(labels)
    weights = [(1.0-beta)/(1.0-beta**counter.get(cls,1)) for cls in CLASSES]
    weights = torch.tensor(weights, dtype=torch.float)
    return weights / weights.sum() * len(CLASSES)

print("✅ 유틸 함수 정의 완료")
class FocalLoss(nn.Module):
    def __init__(self, alpha=None, gamma=2.0, label_smoothing=0.0, reduction="mean"):
        super().__init__()
        self.alpha = alpha; self.gamma = gamma
        self.label_smoothing = label_smoothing; self.reduction = reduction

    def forward(self, logits, targets):
        num_classes = logits.size(1)
        with torch.no_grad():
            smooth_targets = torch.zeros_like(logits)
            smooth_targets.fill_(self.label_smoothing / (num_classes - 1))
            smooth_targets.scatter_(1, targets.unsqueeze(1), 1.0 - self.label_smoothing)
        log_probs = F.log_softmax(logits, dim=1)
        p_t = (log_probs.exp() * smooth_targets).sum(dim=1)
        focal_weight = (1.0 - p_t) ** self.gamma
        ce_loss = -(smooth_targets * log_probs).sum(dim=1)
        if self.alpha is not None:
            alpha = self.alpha.to(logits.device)
            loss = (alpha * smooth_targets).sum(dim=1) * focal_weight * ce_loss
        else:
            loss = focal_weight * ce_loss
        return loss.mean() if self.reduction == "mean" else loss.sum()


class AlzheimerDataset(Dataset):
    def __init__(self, df, img_dir, transform=None, is_test=False):
        self.df = df.reset_index(drop=True)
        self.img_dir = img_dir; self.transform = transform; self.is_test = is_test

    def __len__(self): return len(self.df)

    def __getitem__(self, idx):
        row = self.df.iloc[idx]
        try: image = Image.open(os.path.join(self.img_dir, row["filename"])).convert("RGB")
        except: image = Image.new("RGB", (CFG["img_size"], CFG["img_size"]), 0)
        if self.transform: image = self.transform(image)
        if self.is_test: return image, row["filename"]
        return image, CLASS2IDX[row["label"]]


def get_transforms(phase, img_size):
    mean, std = [0.485,0.456,0.406], [0.229,0.224,0.225]
    if phase == "train":
        return T.Compose([
            T.Resize((img_size+32, img_size+32)), T.RandomCrop(img_size),
            T.RandomHorizontalFlip(p=0.5),
            T.RandomRotation(degrees=10),
            T.ColorJitter(brightness=0.2, contrast=0.2, saturation=0.1),
            T.GaussianBlur(kernel_size=3, sigma=(0.1, 1.5)),
            T.ToTensor(), T.Normalize(mean, std),
        ])
    elif phase == "tta":
        return T.Compose([
            T.Resize((img_size+16, img_size+16)), T.RandomCrop(img_size),
            T.RandomHorizontalFlip(p=0.5), T.RandomRotation(degrees=10),
            T.ToTensor(), T.Normalize(mean, std),
        ])
    return T.Compose([T.Resize((img_size, img_size)), T.ToTensor(), T.Normalize(mean, std)])

print("✅ FocalLoss / Dataset / Transform 정의 완료")
class AlzheimerModel(nn.Module):
    def __init__(self, model_name, num_classes, pretrained, drop_rate):
        super().__init__()
        self.backbone = timm.create_model(model_name, pretrained=pretrained,
                                          num_classes=0, drop_rate=drop_rate)
        in_features = self.backbone.num_features
        self.head = nn.Sequential(
            nn.LayerNorm(in_features), nn.Dropout(drop_rate),
            nn.Linear(in_features, 512), nn.GELU(),
            nn.Dropout(drop_rate * 0.5), nn.Linear(512, num_classes),
        )
    def forward(self, x): return self.head(self.backbone(x))

def mixup_data(x, y, alpha=0.4):
    lam = np.random.beta(alpha, alpha) if alpha > 0 else 1.0
    index = torch.randperm(x.size(0), device=x.device)
    return lam*x + (1-lam)*x[index], y, y[index], lam

def mixup_criterion(criterion, pred, y_a, y_b, lam):
    return lam * criterion(pred, y_a) + (1-lam) * criterion(pred, y_b)

print("✅ 모델 정의 완료")
def train_one_epoch(model, loader, optimizer, criterion, scaler, device, use_amp, use_mixup=True):
    model.train()
    total_loss, all_preds, all_labels = 0.0, [], []
    for images, labels in tqdm(loader, desc="  [Train]", leave=False):
        images = images.to(device, non_blocking=True)
        labels = labels.to(device, non_blocking=True)
        do_mixup = use_mixup and random.random() < 0.5
        if do_mixup: images, labels_a, labels_b, lam = mixup_data(images, labels)
        optimizer.zero_grad(set_to_none=True)
        with autocast(enabled=use_amp):
            logits = model(images)
            loss = mixup_criterion(criterion, logits, labels_a, labels_b, lam) if do_mixup else criterion(logits, labels)
        scaler.scale(loss).backward()
        scaler.unscale_(optimizer)
        torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0)
        scaler.step(optimizer); scaler.update()
        total_loss += loss.item() * len(labels)
        all_preds.extend(logits.argmax(1).cpu().numpy())
        all_labels.extend((labels_a if do_mixup else labels).cpu().numpy())
    return total_loss/len(loader.dataset), f1_score(all_labels, all_preds, average="macro", zero_division=0)

@torch.no_grad()
def validate(model, loader, criterion, device, use_amp):
    model.eval()
    total_loss, all_probs, all_preds, all_labels = 0.0, [], [], []
    for images, labels in tqdm(loader, desc="  [Valid]", leave=False):
        images = images.to(device, non_blocking=True)
        labels = labels.to(device, non_blocking=True)
        with autocast(enabled=use_amp):
            logits = model(images); loss = criterion(logits, labels)
        total_loss += loss.item() * len(labels)
        probs = torch.softmax(logits, 1).cpu().numpy()
        all_probs.extend(probs); all_preds.extend(logits.argmax(1).cpu().numpy())
        all_labels.extend(labels.cpu().numpy())
    return (total_loss/len(loader.dataset),
            f1_score(all_labels, all_preds, average="macro", zero_division=0),
            np.array(all_probs), np.array(all_labels))

print("✅ 학습/검증 루프 정의 완료")
def optimize_thresholds(probs, true_labels, n_search=200):
    best_f1, best_thresh = 0.0, np.ones(CFG["num_classes"]) * 0.25
    for _ in range(n_search):
        thresh = np.random.dirichlet(np.ones(CFG["num_classes"]))
        preds  = (probs / (thresh + 1e-9)).argmax(axis=1)
        f1     = f1_score(true_labels, preds, average="macro", zero_division=0)
        if f1 > best_f1: best_f1 = f1; best_thresh = thresh.copy()
    print(f"  ✅ Threshold 최적화: {best_f1:.4f}")
    for i, cls in enumerate(CLASSES): print(f"     {cls:<22}: {best_thresh[i]:.4f}")
    return best_thresh

def apply_threshold(probs, thresh):
    return (probs / (thresh + 1e-9)).argmax(axis=1)

@torch.no_grad()
def predict_with_tta(model, df, img_dir, device, use_amp, tta_times=1):
    model.eval()
    final_probs = np.zeros((len(df), CFG["num_classes"]))
    transforms_list = ([get_transforms("val", CFG["img_size"])] +
                       [get_transforms("tta", CFG["img_size"]) for _ in range(tta_times-1)])
    for t_idx, transform in enumerate(transforms_list):
        dataset = AlzheimerDataset(df, img_dir, transform, is_test=True)
        loader  = DataLoader(dataset, batch_size=CFG["batch_size"], shuffle=False,
                             num_workers=CFG["num_workers"], pin_memory=True)
        fold_probs = []
        for images, _ in tqdm(loader, desc=f"  [TTA {t_idx+1}]", leave=False):
            images = images.to(device, non_blocking=True)
            with autocast(enabled=use_amp):
                probs = torch.softmax(model(images), 1).cpu().numpy()
            fold_probs.append(probs)
        final_probs += np.vstack(fold_probs) / len(transforms_list)
    return final_probs, df["filename"].tolist()

print("✅ Threshold / TTA 정의 완료")
seed_everything(CFG["seed"])
os.makedirs(CFG["output_dir"], exist_ok=True)
device = CFG["device"]

train_df  = pd.read_csv(CFG["train_csv"])
sample_df = pd.read_csv(CFG["sample_submission_csv"])
test_df   = sample_df[["filename"]].copy()

print_class_distribution(train_df, "학습 데이터 클래스 분포")
print(f"\n  Train: {len(train_df):,}  |  Test: {len(test_df):,}")

class_weight_vec = get_class_weights_for_loss(train_df["label"].tolist(), CFG["sampler_beta"])
print(f"  Focal Loss α: {dict(zip(CLASSES, class_weight_vec.numpy().round(4)))}")

skf        = StratifiedKFold(n_splits=CFG["num_folds"], shuffle=True, random_state=CFG["seed"])
oof_probs  = np.zeros((len(train_df), CFG["num_classes"]))
test_probs = np.zeros((len(test_df),  CFG["num_classes"]))
fold_best_f1s = []

for fold, (tr_idx, val_idx) in enumerate(skf.split(train_df, train_df["label"]), start=1):
    print(f"\n{'═'*55}\n  FOLD {fold} / {CFG['num_folds']}\n{'═'*55}")
    tr_df  = train_df.iloc[tr_idx].reset_index(drop=True)
    val_df = train_df.iloc[val_idx].reset_index(drop=True)

    tr_dataset  = AlzheimerDataset(tr_df,  CFG["train_img_dir"], get_transforms("train", CFG["img_size"]))
    val_dataset = AlzheimerDataset(val_df, CFG["train_img_dir"], get_transforms("val",   CFG["img_size"]))

    sampler   = WeightedRandomSampler(get_sample_weights(tr_df["label"].tolist(), CFG["sampler_beta"]),
                                      len(tr_df), replacement=True)
    tr_loader = DataLoader(tr_dataset, batch_size=CFG["batch_size"], sampler=sampler,
                           num_workers=CFG["num_workers"], pin_memory=True, drop_last=True)
    val_loader= DataLoader(val_dataset, batch_size=CFG["batch_size"], shuffle=False,
                           num_workers=CFG["num_workers"], pin_memory=True)

    model = AlzheimerModel(CFG["model_name"], CFG["num_classes"],
                           CFG["pretrained"], CFG["drop_rate"]).to(device)
    criterion = FocalLoss(alpha=class_weight_vec, gamma=CFG["focal_gamma"],
                          label_smoothing=CFG["label_smoothing"])
    optimizer = optim.AdamW(model.parameters(), lr=CFG["lr"], weight_decay=CFG["weight_decay"])
    warmup_epochs = 3
    scheduler = optim.lr_scheduler.SequentialLR(optimizer, schedulers=[
        optim.lr_scheduler.LinearLR(optimizer, start_factor=0.1, end_factor=1.0, total_iters=warmup_epochs),
        optim.lr_scheduler.CosineAnnealingLR(optimizer, T_max=CFG["num_epochs"]-warmup_epochs, eta_min=CFG["min_lr"]),
    ], milestones=[warmup_epochs])
    scaler = GradScaler(enabled=CFG["use_amp"])
    best_f1, no_improv = 0.0, 0
    best_path = os.path.join(CFG["output_dir"], f"fold{fold}_best.pth")

    for epoch in range(1, CFG["num_epochs"]+1):
        use_mixup = epoch > warmup_epochs
        tr_loss, tr_f1 = train_one_epoch(model, tr_loader, optimizer, criterion,
                                          scaler, device, CFG["use_amp"], use_mixup)
        val_loss, val_f1, val_probs_ep, _ = validate(model, val_loader, criterion, device, CFG["use_amp"])
        scheduler.step()
        flag = ""
        if val_f1 > best_f1:
            best_f1 = val_f1; no_improv = 0
            torch.save({"model": model.state_dict(), "epoch": epoch, "f1": best_f1}, best_path)
            oof_probs[val_idx] = val_probs_ep; flag = "  ★ BEST"
        else: no_improv += 1
        print(f"  Ep[{epoch:02d}/{CFG['num_epochs']}] lr={optimizer.param_groups[0]['lr']:.2e}  "
              f"tr_f1={tr_f1:.4f}  |  val_f1={val_f1:.4f}{flag}")
        if no_improv >= CFG["patience"]: print(f"  ⏹ Early Stop"); break

    fold_best_f1s.append(best_f1)
    ckpt = torch.load(best_path, map_location=device)
    model.load_state_dict(ckpt["model"])
    fold_test_probs, test_filenames = predict_with_tta(model, test_df, CFG["test_img_dir"],
                                                        device, CFG["use_amp"], CFG["tta_times"])
    test_probs += fold_test_probs / CFG["num_folds"]
    print(f"  Fold {fold} 최고 Val F1: {best_f1:.4f}")

print(f"\n{'═'*55}\n  K-Fold 결과 요약\n{'═'*55}")
for i, f1 in enumerate(fold_best_f1s, 1): print(f"  Fold {i}: {f1:.4f}")
print(f"  평균: {np.mean(fold_best_f1s):.4f} ± {np.std(fold_best_f1s):.4f}")
oof_true = train_df["label"].map(CLASS2IDX).values
oof_f1   = f1_score(oof_true, oof_probs.argmax(1), average="macro", zero_division=0)
print(f"  OOF Macro F1: {oof_f1:.4f}")

best_thresh   = optimize_thresholds(oof_probs, oof_true, n_search=200)
oof_preds_opt = apply_threshold(oof_probs, best_thresh)
print(f"  OOF F1 (threshold): {f1_score(oof_true, oof_preds_opt, average="macro", zero_division=0):.4f}")

labels_raw = [IDX2CLASS[i] for i in test_probs.argmax(1)]
labels_opt = [IDX2CLASS[i] for i in apply_threshold(test_probs, best_thresh)]

order = {fn: i for i, fn in enumerate(sample_df["filename"])}
for name, labels in [("submission_raw.csv", labels_raw), ("submission_optimized.csv", labels_opt)]:
    sub = pd.DataFrame({"filename": test_filenames, "label": labels})
    sub = sub.sort_values("filename", key=lambda s: s.map(order)).reset_index(drop=True)
    sub.to_csv(os.path.join(CFG["output_dir"], name), index=False)
    print(f"  저장: {name}")

print("\n예측 분포 (optimized):")
print(pd.Series(labels_opt).value_counts())
print("\n✅ 완료! submission_optimized.csv 제출하세요")
