    "timm": "timm", "sklearn": "scikit-learn",
    "tqdm": "tqdm", "PIL": "Pillow",
    "torch": "torch", "torchvision": "torchvision",
}
for import_name, pkg_name in REQUIRED.items():
    try:
        __import__(import_name)
    except ImportError:
        print(f"[설치] {pkg_name} ...")
        install(pkg_name)
